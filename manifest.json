<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0d0d0d" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Lifts" />
  <meta name="description" content="Minimal gym tracking. Log sets, track progress." />
  <link rel="manifest" href="manifest.json" />
  <link rel="icon" href="icons/icon-192.png" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <title>Lifts</title>
  <style>
    :root {
      --bg: #0d0d0d;
      --surface: #161616;
      --surface2: #1e1e1e;
      --border: rgba(255,255,255,0.08);
      --border2: rgba(255,255,255,0.14);
      --text: #f0ede8;
      --muted: rgba(240,237,232,0.45);
      --accent: #c8f060;
      --accent-dim: rgba(200,240,96,0.12);
      --danger: #ff5a5a;
      --mono: 'DM Mono', monospace;
      --sans: 'DM Sans', sans-serif;
      --safe-top: env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--sans); -webkit-font-smoothing: antialiased; overscroll-behavior: none; }
    body { display: flex; flex-direction: column; }
    .app { display: flex; flex-direction: column; height: 100dvh; }

    .header { padding: calc(var(--safe-top) + 18px) 20px 14px; display: flex; align-items: flex-end; justify-content: space-between; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .header-title { font-family: var(--mono); font-size: 22px; font-weight: 500; letter-spacing: -0.5px; }
    .header-title span { color: var(--accent); }
    .header-date { font-size: 12px; color: var(--muted); font-family: var(--mono); }

    .content { flex: 1; overflow-y: auto; padding: 16px 20px; }

    .nav { display: flex; border-top: 1px solid var(--border); flex-shrink: 0; padding-bottom: var(--safe-bottom); background: var(--surface); }
    .nav-btn { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 12px 0; font-size: 11px; color: var(--muted); cursor: pointer; font-family: var(--mono); border: none; background: none; transition: color 0.15s; -webkit-tap-highlight-color: transparent; }
    .nav-btn svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
    .nav-btn.active { color: var(--accent); }

    .tab { display: none; }
    .tab.active { display: block; }

    /* Day strip */
    .day-strip { display: flex; gap: 8px; margin-bottom: 18px; overflow-x: auto; padding-bottom: 2px; scrollbar-width: none; }
    .day-strip::-webkit-scrollbar { display: none; }
    .day-chip { flex-shrink: 0; padding: 7px 16px; border-radius: 20px; border: 1px solid var(--border2); font-size: 13px; font-family: var(--mono); color: var(--muted); cursor: pointer; background: none; -webkit-tap-highlight-color: transparent; transition: all 0.15s; }
    .day-chip.active { background: var(--accent); color: #0d0d0d; border-color: var(--accent); font-weight: 500; }
    .day-chip.has-template { border-color: rgba(200,240,96,0.3); color: var(--text); }

    /* Day name */
    .day-header-row { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .day-name-display { font-size: 18px; font-weight: 500; letter-spacing: -0.3px; flex: 1; }
    .day-name-input { background: var(--surface2); border: 1px solid var(--accent); border-radius: 8px; color: var(--text); font-family: var(--sans); font-size: 16px; font-weight: 500; padding: 6px 10px; flex: 1; }
    .day-name-input:focus { outline: none; }
    .icon-btn { background: none; border: none; color: var(--muted); cursor: pointer; padding: 4px; font-size: 16px; -webkit-tap-highlight-color: transparent; }
    .icon-btn:active { color: var(--accent); }

    /* Exercise card */
    .exercise-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; margin-bottom: 14px; overflow: hidden; }
    .exercise-card-header { display: flex; align-items: center; justify-content: space-between; padding: 13px 16px 0; }
    .exercise-card-name { font-size: 15px; font-weight: 500; letter-spacing: -0.2px; }
    .ex-remove-btn { background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 0 2px; line-height: 1; -webkit-tap-highlight-color: transparent; }
    .ex-remove-btn:active { color: var(--danger); }

    /* Sets section */
    .sets-section { padding: 10px 16px 0; }
    .sets-col-labels { display: grid; grid-template-columns: 22px 1fr 1fr 32px; gap: 8px; font-size: 10px; color: var(--muted); font-family: var(--mono); text-align: center; margin-bottom: 4px; padding: 0 2px; }
    .sets-col-labels span:first-child { text-align: left; }

    .set-row { display: grid; grid-template-columns: 22px 1fr 1fr 32px; gap: 8px; align-items: center; padding: 5px 0; }
    .set-num { font-size: 11px; color: var(--muted); font-family: var(--mono); text-align: left; }
    .set-input { background: var(--surface2); border: 1px solid var(--border); border-radius: 7px; color: var(--text); font-family: var(--mono); font-size: 15px; padding: 7px 6px; width: 100%; text-align: center; -webkit-appearance: none; transition: border-color 0.15s; }
    .set-input:focus { outline: none; border-color: var(--accent); }
    .set-del { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 18px; line-height: 1; text-align: center; padding: 0; -webkit-tap-highlight-color: transparent; }
    .set-del:active { color: var(--danger); }

    /* Set count stepper */
    .set-count-row { display: flex; align-items: center; gap: 10px; padding: 10px 16px 0; }
    .set-count-label { font-size: 11px; color: var(--muted); font-family: var(--mono); flex: 1; }
    .stepper { display: flex; align-items: center; gap: 0; border: 1px solid var(--border2); border-radius: 8px; overflow: hidden; }
    .stepper-btn { background: none; border: none; color: var(--text); font-size: 18px; width: 34px; height: 30px; cursor: pointer; display: flex; align-items: center; justify-content: center; -webkit-tap-highlight-color: transparent; font-family: var(--mono); }
    .stepper-btn:active { background: var(--surface2); }
    .stepper-val { font-size: 14px; font-family: var(--mono); min-width: 22px; text-align: center; color: var(--accent); }

    /* History beneath exercise */
    .ex-history { margin: 10px 16px 0; padding: 10px 12px; background: var(--surface2); border-radius: 8px; border-left: 2px solid rgba(200,240,96,0.25); }
    .ex-history-label { font-size: 10px; font-family: var(--mono); color: var(--accent); letter-spacing: 0.06em; margin-bottom: 7px; opacity: 0.8; }
    .ex-history-row { display: grid; grid-template-columns: 22px 1fr 1fr; gap: 8px; font-size: 12px; font-family: var(--mono); color: var(--muted); padding: 2px 0; }
    .ex-history-row span:first-child { color: rgba(240,237,232,0.25); }

    /* Card footer */
    .card-footer { display: flex; align-items: center; padding: 10px 16px 13px; margin-top: 6px; border-top: 1px solid var(--border); gap: 8px; }
    .add-set-btn { background: none; border: none; color: var(--muted); font-size: 12px; font-family: var(--mono); cursor: pointer; -webkit-tap-highlight-color: transparent; padding: 0; }
    .add-set-btn:active { color: var(--accent); }

    /* Add exercise form */
    .add-form { background: var(--surface); border: 1px solid var(--border2); border-radius: 14px; padding: 16px; margin-bottom: 14px; }
    .add-form h3 { font-size: 12px; font-family: var(--mono); color: var(--muted); margin-bottom: 14px; letter-spacing: 0.06em; text-transform: uppercase; }
    .form-group { margin-bottom: 12px; }
    .form-label { font-size: 11px; color: var(--muted); font-family: var(--mono); margin-bottom: 5px; display: block; }
    .form-input { width: 100%; background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-family: var(--sans); font-size: 15px; padding: 10px 12px; -webkit-appearance: none; }
    .form-input:focus { outline: none; border-color: var(--accent); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
    .form-row .form-input { text-align: center; font-family: var(--mono); }
    .form-actions { display: flex; gap: 8px; margin-top: 16px; }
    .btn-accent { flex: 1; background: var(--accent); color: #0d0d0d; border: none; border-radius: 8px; padding: 11px; font-size: 14px; font-weight: 600; font-family: var(--sans); cursor: pointer; }
    .btn-accent:active { opacity: 0.85; }
    .btn-ghost { background: none; border: 1px solid var(--border2); border-radius: 8px; padding: 11px 18px; color: var(--muted); font-size: 14px; font-family: var(--sans); cursor: pointer; }
    .btn-ghost:active { background: var(--surface2); }
    .fab-add { background: none; border: 2px dashed var(--border2); border-radius: 12px; padding: 13px; color: var(--muted); font-size: 13px; font-family: var(--mono); cursor: pointer; width: 100%; margin-bottom: 12px; -webkit-tap-highlight-color: transparent; letter-spacing: 0.02em; }
    .fab-add:active { border-color: var(--accent); color: var(--accent); }

    /* Save bar */
    .save-bar { padding: 12px 20px; border-top: 1px solid var(--border); flex-shrink: 0; background: var(--bg); }
    .fab { width: 100%; background: var(--accent); color: #0d0d0d; border: none; border-radius: 10px; padding: 14px; font-size: 15px; font-weight: 600; font-family: var(--sans); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .fab:active { opacity: 0.85; }

    /* Load template */
    .load-tmpl-btn { width: 100%; background: var(--accent-dim); border: 1px solid rgba(200,240,96,0.25); border-radius: 10px; padding: 12px; font-size: 13px; font-family: var(--mono); color: var(--accent); cursor: pointer; margin-bottom: 14px; -webkit-tap-highlight-color: transparent; }
    .load-tmpl-btn:active { background: rgba(200,240,96,0.2); }
    .tmpl-hint { font-size: 12px; color: var(--muted); font-family: var(--mono); margin-bottom: 10px; line-height: 1.6; }

    /* Program tab */
    .program-day-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .program-day-card:active { background: var(--surface2); }
    .program-day-left { display: flex; align-items: center; gap: 12px; }
    .program-day-num { font-size: 12px; font-family: var(--mono); color: var(--accent); background: var(--accent-dim); border-radius: 6px; padding: 4px 8px; min-width: 28px; text-align: center; }
    .program-day-name { font-size: 15px; font-weight: 500; }
    .program-day-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .program-day-arrow { color: var(--muted); font-size: 20px; }
    .section-label { font-size: 11px; font-family: var(--mono); color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }

    /* History tab */
    .history-day-item { margin-bottom: 20px; }
    .history-day-header { font-size: 11px; font-family: var(--mono); color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between; }
    .history-del-btn { background: none; border: none; color: var(--muted); font-size: 12px; font-family: var(--mono); cursor: pointer; padding: 2px 6px; -webkit-tap-highlight-color: transparent; }
    .history-del-btn:active { color: var(--danger); }
    .history-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }
    .history-day-badge { display: inline-block; font-size: 11px; font-family: var(--mono); background: var(--accent-dim); color: var(--accent); border-radius: 4px; padding: 2px 7px; margin-bottom: 10px; }
    .history-exercise { margin-bottom: 10px; }
    .history-exercise:last-child { margin-bottom: 0; }
    .history-ex-name { font-size: 14px; font-weight: 500; margin-bottom: 5px; }
    .history-sets-grid { display: grid; grid-template-columns: 22px 1fr 1fr; gap: 6px; font-size: 12px; font-family: var(--mono); }
    .history-sets-grid .hdr { font-size: 10px; color: var(--muted); opacity: 0.7; }
    .history-sets-grid .num { color: rgba(240,237,232,0.3); }
    .history-sets-grid .val { color: var(--muted); }

    /* Empty */
    .empty { text-align: center; padding: 48px 0 24px; }
    .empty-icon { font-size: 36px; margin-bottom: 12px; }
    .empty-title { font-size: 16px; font-weight: 500; margin-bottom: 6px; }
    .empty-sub { font-size: 13px; color: var(--muted); line-height: 1.6; }

    /* Toast */
    .toast { position: fixed; bottom: calc(var(--safe-bottom) + 80px); left: 50%; transform: translateX(-50%) translateY(20px); background: var(--surface2); border: 1px solid var(--border2); color: var(--text); font-size: 13px; font-family: var(--mono); padding: 10px 20px; border-radius: 24px; opacity: 0; transition: all 0.25s; pointer-events: none; white-space: nowrap; z-index: 999; }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @keyframes slideIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .exercise-card, .add-form { animation: slideIn 0.18s ease; }
  </style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="header-title">li<span>f</span>ts</div>
    <div class="header-date" id="header-date"></div>
  </div>
  <div class="content">
    <div class="tab active" id="tab-log"></div>
    <div class="tab" id="tab-program"></div>
    <div class="tab" id="tab-history"></div>
  </div>
  <div class="save-bar" id="save-bar" style="display:none;">
    <button class="fab" onclick="saveWorkout()">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      Save workout
    </button>
  </div>
  <nav class="nav">
    <button class="nav-btn active" id="nav-log" onclick="switchTab('log')">
      <svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      today
    </button>
    <button class="nav-btn" id="nav-program" onclick="switchTab('program')">
      <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      program
    </button>
    <button class="nav-btn" id="nav-history" onclick="switchTab('history')">
      <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      history
    </button>
  </nav>
</div>
<div class="toast" id="toast"></div>

<script>
const NUM_DAYS = 5;
let activeDay = 0;
let exercises = [];   // [{name, sets:[{reps,weight}]}]
let showingForm = false;
let editingDayName = false;
let programEditDay = null;
let programShowForm = false;

// ── Storage ───────────────────────────────────────────────────────────────
const ls = {
  get: k => { try { const v=localStorage.getItem(k); return v?JSON.parse(v):null; } catch(e){ return null; } },
  set: (k,v) => { try { localStorage.setItem(k,JSON.stringify(v)); } catch(e){} },
  del: k => { try { localStorage.removeItem(k); } catch(e){} },
  keys: p => { const out=[]; for(let i=0;i<localStorage.length;i++){ const k=localStorage.key(i); if(k&&k.startsWith(p)) out.push(k); } return out; }
};

// ── Program templates ─────────────────────────────────────────────────────
function getProgram() {
  return ls.get('lifts_program') || Array.from({length:NUM_DAYS},(_,i)=>({name:`Day ${i+1}`,exercises:[]}));
}
function saveProgram(p) { ls.set('lifts_program',p); }

// ── Last session history per exercise name + day ──────────────────────────
// Returns the sets [{reps,weight}] from the most recent saved workout on dayIdx
// that contains an exercise matching name (case-insensitive).
function getLastSessionSets(dayIdx, exerciseName) {
  const nameNorm = exerciseName.trim().toLowerCase();
  // Get all workout keys for this day, sorted newest first
  const prefix = `lifts_workout_`;
  const allKeys = ls.keys(prefix)
    .filter(k => k.includes(`_d${dayIdx}`))
    .sort().reverse();
  for (const k of allKeys) {
    const w = ls.get(k);
    if (!w) continue;
    const match = w.exercises.find(e => e.name.trim().toLowerCase() === nameNorm);
    if (match) return { date: w.date, sets: match.sets };
  }
  return null;
}

// ── Utils ─────────────────────────────────────────────────────────────────
function todayKey() { return new Date().toISOString().slice(0,10); }
function fmtShortDate(d) {
  const dt = new Date(d+'T12:00:00');
  return dt.toLocaleDateString('en-SE',{month:'short',day:'numeric'});
}
function fmtFull(d) { return new Date(d+'T12:00:00').toLocaleDateString('en-SE',{weekday:'long',year:'numeric',month:'long',day:'numeric'}); }
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

document.getElementById('header-date').textContent =
  new Date().toLocaleDateString('en-SE',{weekday:'short',month:'short',day:'numeric'}).toUpperCase();

// ── Tab switching ─────────────────────────────────────────────────────────
function switchTab(t) {
  ['log','program','history'].forEach(n=>{
    document.getElementById('tab-'+n).classList.toggle('active',n===t);
    document.getElementById('nav-'+n).classList.toggle('active',n===t);
  });
  document.getElementById('save-bar').style.display=(t==='log'&&exercises.length>0)?'':'none';
  if(t==='log') renderLog();
  if(t==='program') renderProgram();
  if(t==='history') renderHistory();
}

// ── LOG TAB ───────────────────────────────────────────────────────────────
function renderLog() {
  const el = document.getElementById('tab-log');
  const program = getProgram();
  document.getElementById('save-bar').style.display = exercises.length>0?'':'none';

  // Day strip
  let html = `<div class="day-strip">`;
  for(let i=0;i<NUM_DAYS;i++){
    const hasTmpl = program[i].exercises.length>0;
    const cls = (i===activeDay?'active':'')+(hasTmpl&&i!==activeDay?' has-template':'');
    html += `<button class="day-chip ${cls}" onclick="selectDay(${i})">${esc(program[i].name)}</button>`;
  }
  html += `</div>`;

  // Day name header
  html += `<div class="day-header-row">`;
  if(editingDayName){
    html += `<input class="day-name-input" id="day-name-input" value="${esc(program[activeDay].name)}" maxlength="20"
      onblur="saveDayName()" onkeydown="if(event.key==='Enter')saveDayName()" />`;
  } else {
    html += `<div class="day-name-display">${esc(program[activeDay].name)}</div>
      <button class="icon-btn" onclick="startEditDayName()">✎</button>`;
  }
  html += `</div>`;

  // Empty state / load template
  if(exercises.length===0 && !showingForm){
    const tmpl = program[activeDay].exercises;
    if(tmpl.length>0){
      html += `<div class="tmpl-hint">template: ${tmpl.map(e=>esc(e.name)).join(' · ')}</div>
        <button class="load-tmpl-btn" onclick="loadTemplate()">↓ load ${esc(program[activeDay].name)} template</button>`;
    } else {
      html += `<div class="empty">
        <div class="empty-icon">🏋️</div>
        <div class="empty-title">No exercises yet</div>
        <div class="empty-sub">Set up a template in the Program tab,<br>or add exercises manually below</div>
      </div>`;
    }
  }

  // Exercise cards
  exercises.forEach((ex, ei) => {
    const history = getLastSessionSets(activeDay, ex.name);
    html += renderExerciseCard(ex, ei, history);
  });

  // Add exercise form / button
  if(showingForm){
    html += `<div class="add-form">
      <h3>new exercise</h3>
      <div class="form-group">
        <label class="form-label">exercise name</label>
        <input class="form-input" id="ex-name" type="text" placeholder="e.g. barbell curl" autocomplete="off" />
      </div>
      <div class="form-row">
        <div><label class="form-label">sets</label><input class="form-input" id="ex-sets" type="number" value="3" min="1" max="10" /></div>
        <div><label class="form-label">reps</label><input class="form-input" id="ex-reps" type="number" value="10" min="1" max="100" /></div>
        <div><label class="form-label">kg</label><input class="form-input" id="ex-weight" type="number" value="20" min="0" step="0.5" /></div>
      </div>
      <div class="form-actions">
        <button class="btn-accent" onclick="confirmAddExercise()">Add</button>
        <button class="btn-ghost" onclick="cancelAdd()">Cancel</button>
      </div>
    </div>`;
  } else {
    html += `<button class="fab-add" onclick="showForm()">+ add exercise</button>`;
  }

  el.innerHTML = html;
  if(editingDayName){ const n=document.getElementById('day-name-input'); if(n){n.focus();n.select();} }
  if(showingForm){ const n=document.getElementById('ex-name'); if(n) n.focus(); }
}

function renderExerciseCard(ex, ei, history) {
  let html = `<div class="exercise-card">
    <div class="exercise-card-header">
      <div class="exercise-card-name">${esc(ex.name)}</div>
      <button class="ex-remove-btn" onclick="removeExercise(${ei})">×</button>
    </div>

    <div class="set-count-row">
      <span class="set-count-label">sets</span>
      <div class="stepper">
        <button class="stepper-btn" onclick="changeSetCount(${ei},-1)">−</button>
        <span class="stepper-val">${ex.sets.length}</span>
        <button class="stepper-btn" onclick="changeSetCount(${ei},1)">+</button>
      </div>
    </div>

    <div class="sets-section">
      <div class="sets-col-labels"><span>#</span><span>reps</span><span>kg</span><span></span></div>
      <div id="sets-${ei}">
        ${ex.sets.map((s,si)=>setRowHtml(ei,si,s)).join('')}
      </div>
    </div>`;

  // History block
  if(history && history.sets && history.sets.length>0){
    html += `<div class="ex-history">
      <div class="ex-history-label">last session · ${fmtShortDate(history.date)}</div>
      <div class="history-sets-grid">
        <span class="hdr"></span><span class="hdr">reps</span><span class="hdr">kg</span>
        ${history.sets.map((s,i)=>`
          <span class="num">${i+1}</span>
          <span class="val">${s.reps}</span>
          <span class="val">${s.weight}</span>
        `).join('')}
      </div>
    </div>`;
  }

  html += `<div class="card-footer">
    <button class="add-set-btn" onclick="addSet(${ei})">+ add set</button>
  </div></div>`;

  return html;
}

function setRowHtml(ei, si, s) {
  return `<div class="set-row">
    <span class="set-num">${si+1}</span>
    <input class="set-input" type="number" value="${s.reps}" min="1" max="999"
      inputmode="numeric" onchange="updateSet(${ei},${si},'reps',this.value)" />
    <input class="set-input" type="number" value="${s.weight}" min="0" step="0.5"
      inputmode="decimal" onchange="updateSet(${ei},${si},'weight',this.value)" />
    <button class="set-del" onclick="removeSet(${ei},${si})">×</button>
  </div>`;
}

function changeSetCount(ei, delta) {
  const ex = exercises[ei];
  const newCount = Math.max(1, Math.min(10, ex.sets.length + delta));
  if(newCount > ex.sets.length){
    const last = ex.sets.slice(-1)[0] || {reps:10,weight:20};
    ex.sets.push({...last});
  } else if(newCount < ex.sets.length){
    ex.sets.pop();
  }
  // Re-render just this card for speed
  const history = getLastSessionSets(activeDay, ex.name);
  const cards = document.querySelectorAll('.exercise-card');
  if(cards[ei]){
    const tmp = document.createElement('div');
    tmp.innerHTML = renderExerciseCard(ex, ei, history);
    cards[ei].replaceWith(tmp.firstElementChild);
  }
  document.getElementById('save-bar').style.display = exercises.length>0?'':'none';
}

function updateSet(ei,si,f,v){ exercises[ei].sets[si][f]=parseFloat(v)||0; }

function removeSet(ei,si){
  exercises[ei].sets.splice(si,1);
  if(exercises[ei].sets.length===0){ exercises.splice(ei,1); renderLog(); return; }
  const cont = document.getElementById(`sets-${ei}`);
  if(cont) cont.innerHTML = exercises[ei].sets.map((s,si)=>setRowHtml(ei,si,s)).join('');
  // update stepper display
  const card = cont?.closest('.exercise-card');
  if(card){ const sv=card.querySelector('.stepper-val'); if(sv) sv.textContent=exercises[ei].sets.length; }
}

function addSet(ei){
  const last = exercises[ei].sets.slice(-1)[0]||{reps:10,weight:20};
  exercises[ei].sets.push({...last});
  const cont = document.getElementById(`sets-${ei}`);
  if(cont) cont.innerHTML = exercises[ei].sets.map((s,si)=>setRowHtml(ei,si,s)).join('');
  const card = cont?.closest('.exercise-card');
  if(card){ const sv=card.querySelector('.stepper-val'); if(sv) sv.textContent=exercises[ei].sets.length; }
  document.getElementById('save-bar').style.display='';
}

function removeExercise(ei){ exercises.splice(ei,1); renderLog(); }

function selectDay(i){
  if(exercises.length>0&&!confirm('Switch day? Unsaved exercises will be lost.')) return;
  activeDay=i; exercises=[]; showingForm=false; editingDayName=false; renderLog();
}

function loadTemplate(){
  const tmpl = getProgram()[activeDay].exercises;
  exercises = tmpl.map(ex=>({name:ex.name, sets:ex.sets.map(s=>({...s}))}));
  renderLog();
}

function startEditDayName(){ editingDayName=true; renderLog(); }
function saveDayName(){
  const inp=document.getElementById('day-name-input'); if(!inp) return;
  const val=inp.value.trim()||`Day ${activeDay+1}`;
  const p=getProgram(); p[activeDay].name=val; saveProgram(p);
  editingDayName=false; renderLog();
}

function showForm(){ showingForm=true; renderLog(); }
function cancelAdd(){ showingForm=false; renderLog(); }

function confirmAddExercise(){
  const name=document.getElementById('ex-name').value.trim();
  const sets=parseInt(document.getElementById('ex-sets').value)||1;
  const reps=parseInt(document.getElementById('ex-reps').value)||1;
  const weight=parseFloat(document.getElementById('ex-weight').value)||0;
  if(!name){ document.getElementById('ex-name').focus(); return; }
  exercises.push({name, sets:Array.from({length:sets},()=>({reps,weight}))});
  showingForm=false; renderLog();
}

function saveWorkout(){
  if(!exercises.length) return;
  const p=getProgram();
  const key=`lifts_workout_${todayKey()}_d${activeDay}`;
  ls.set(key,{date:todayKey(),dayIdx:activeDay,dayName:p[activeDay].name,exercises:JSON.parse(JSON.stringify(exercises))});
  exercises=[]; showingForm=false; renderLog();
  showToast(`${p[activeDay].name} saved ✓`);
}

// ── PROGRAM TAB ───────────────────────────────────────────────────────────
function renderProgram(){
  const el=document.getElementById('tab-program');
  if(programEditDay===null){
    const program=getProgram();
    let html=`<div class="section-label">your program</div>`;
    program.forEach((day,i)=>{
      const n=day.exercises.length;
      html+=`<div class="program-day-card" onclick="openProgramDay(${i})">
        <div class="program-day-left">
          <div class="program-day-num">D${i+1}</div>
          <div>
            <div class="program-day-name">${esc(day.name)}</div>
            <div class="program-day-sub">${n>0?n+' exercise'+(n!==1?'s':''):'no exercises yet'}</div>
          </div>
        </div>
        <div class="program-day-arrow">›</div>
      </div>`;
    });
    html+=`<div style="font-size:12px;color:var(--muted);font-family:var(--mono);margin-top:16px;line-height:1.8;">
      Tap a day to set up its exercise template.<br>
      On the Today tab, select a day and tap "load template".
    </div>`;
    el.innerHTML=html;
  } else {
    renderProgramDayEdit(el);
  }
}

function openProgramDay(i){ programEditDay=i; programShowForm=false; renderProgram(); }
function closeProgramDay(){ programEditDay=null; programShowForm=false; renderProgram(); }

function renderProgramDayEdit(el){
  const program=getProgram(); const day=program[programEditDay];
  let html=`<div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
    <button class="icon-btn" onclick="closeProgramDay()" style="font-size:22px;color:var(--muted);">‹</button>
    <div style="font-size:18px;font-weight:500;">${esc(day.name)}</div>
  </div>`;

  day.exercises.forEach((ex,ei)=>{
    html+=`<div class="exercise-card">
      <div class="exercise-card-header">
        <div class="exercise-card-name">${esc(ex.name)}</div>
        <button class="ex-remove-btn" onclick="removeProgramExercise(${ei})">×</button>
      </div>
      <div class="set-count-row">
        <span class="set-count-label">sets</span>
        <div class="stepper">
          <button class="stepper-btn" onclick="changeProgramSetCount(${ei},-1)">−</button>
          <span class="stepper-val">${ex.sets.length}</span>
          <button class="stepper-btn" onclick="changeProgramSetCount(${ei},1)">+</button>
        </div>
      </div>
      <div class="sets-section">
        <div class="sets-col-labels"><span>#</span><span>reps</span><span>kg</span><span></span></div>
        <div>${ex.sets.map((s,si)=>`<div class="set-row">
          <span class="set-num">${si+1}</span>
          <input class="set-input" type="number" value="${s.reps}" inputmode="numeric" onchange="updateProgramSet(${ei},${si},'reps',this.value)" />
          <input class="set-input" type="number" value="${s.weight}" step="0.5" inputmode="decimal" onchange="updateProgramSet(${ei},${si},'weight',this.value)" />
          <button class="set-del" onclick="removeProgramSet(${ei},${si})">×</button>
        </div>`).join('')}</div>
      </div>
      <div class="card-footer"><button class="add-set-btn" onclick="addProgramSet(${ei})">+ add set</button></div>
    </div>`;
  });

  if(programShowForm){
    html+=`<div class="add-form">
      <h3>new exercise</h3>
      <div class="form-group"><label class="form-label">exercise name</label>
        <input class="form-input" id="pex-name" type="text" placeholder="e.g. squat" autocomplete="off" /></div>
      <div class="form-row">
        <div><label class="form-label">sets</label><input class="form-input" id="pex-sets" type="number" value="3" min="1" max="10" /></div>
        <div><label class="form-label">reps</label><input class="form-input" id="pex-reps" type="number" value="10" min="1" max="100" /></div>
        <div><label class="form-label">kg</label><input class="form-input" id="pex-weight" type="number" value="20" min="0" step="0.5" /></div>
      </div>
      <div class="form-actions">
        <button class="btn-accent" onclick="confirmAddProgramExercise()">Add</button>
        <button class="btn-ghost" onclick="programShowForm=false;renderProgram()">Cancel</button>
      </div></div>`;
  } else {
    html+=`<button class="fab-add" onclick="programShowForm=true;renderProgram()">+ add exercise</button>`;
  }
  el.innerHTML=html;
  if(programShowForm){ const n=document.getElementById('pex-name'); if(n) n.focus(); }
}

function changeProgramSetCount(ei, delta){
  const p=getProgram(); const ex=p[programEditDay].exercises[ei];
  const newCount=Math.max(1,Math.min(10,ex.sets.length+delta));
  if(newCount>ex.sets.length){ const last=ex.sets.slice(-1)[0]||{reps:10,weight:20}; ex.sets.push({...last}); }
  else if(newCount<ex.sets.length){ ex.sets.pop(); }
  saveProgram(p); renderProgram();
}
function confirmAddProgramExercise(){
  const name=document.getElementById('pex-name').value.trim();
  const sets=parseInt(document.getElementById('pex-sets').value)||1;
  const reps=parseInt(document.getElementById('pex-reps').value)||1;
  const weight=parseFloat(document.getElementById('pex-weight').value)||0;
  if(!name){ document.getElementById('pex-name').focus(); return; }
  const p=getProgram(); p[programEditDay].exercises.push({name,sets:Array.from({length:sets},()=>({reps,weight}))});
  saveProgram(p); programShowForm=false; renderProgram();
}
function removeProgramExercise(ei){ const p=getProgram(); p[programEditDay].exercises.splice(ei,1); saveProgram(p); renderProgram(); }
function updateProgramSet(ei,si,f,v){ const p=getProgram(); p[programEditDay].exercises[ei].sets[si][f]=parseFloat(v)||0; saveProgram(p); }
function addProgramSet(ei){ const p=getProgram(); const last=p[programEditDay].exercises[ei].sets.slice(-1)[0]||{reps:10,weight:20}; p[programEditDay].exercises[ei].sets.push({...last}); saveProgram(p); renderProgram(); }
function removeProgramSet(ei,si){ const p=getProgram(); p[programEditDay].exercises[ei].sets.splice(si,1); if(p[programEditDay].exercises[ei].sets.length===0) p[programEditDay].exercises.splice(ei,1); saveProgram(p); renderProgram(); }

// ── HISTORY TAB ───────────────────────────────────────────────────────────
function renderHistory(){
  const el=document.getElementById('tab-history');
  const keys=ls.keys('lifts_workout_').sort().reverse();
  if(!keys.length){
    el.innerHTML=`<div class="empty"><div class="empty-icon">📋</div><div class="empty-title">No history yet</div><div class="empty-sub">Save your first workout to see it here</div></div>`;
    return;
  }
  let html='';
  keys.forEach(k=>{
    const w=ls.get(k); if(!w) return;
    html+=`<div class="history-day-item">
      <div class="history-day-header">
        <span>${fmtFull(w.date)}</span>
        <button class="history-del-btn" onclick="deleteWorkout('${k}')">delete</button>
      </div>
      <div class="history-card">
        <div class="history-day-badge">${esc(w.dayName||'Workout')}</div>
        ${w.exercises.map(ex=>`
          <div class="history-exercise">
            <div class="history-ex-name">${esc(ex.name)}</div>
            <div class="history-sets-grid">
              <span class="hdr"></span><span class="hdr">reps</span><span class="hdr">kg</span>
              ${ex.sets.map((s,i)=>`<span class="num">${i+1}</span><span class="val">${s.reps}</span><span class="val">${s.weight}</span>`).join('')}
            </div>
          </div>`).join('')}
      </div>
    </div>`;
  });
  el.innerHTML=html;
}
function deleteWorkout(k){ if(!confirm('Delete this workout?')) return; ls.del(k); renderHistory(); showToast('Deleted'); }

function showToast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }

renderLog();
if('serviceWorker' in navigator){ window.addEventListener('load',()=>navigator.serviceWorker.register('sw.js').catch(()=>{})); }
</script>
</body>
</html>
